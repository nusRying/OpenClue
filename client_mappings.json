        "sessionKey": "agent:main:telegram:group:-1003728720677:topic:1",
        "channel": "telegram",
        "to": "-1003728720677:topic:1",
        "deliver": true,
        "allowUnsafeExternalContent": true,
        "messageTemplate": "{{message}}"
      },
      {
        "id": "n8n-digit",
        "match": { "path": "n8n-digit" },
        "action": "agent",
        "agentId": "digit",
        "sessionKey": "agent:digit:telegram:group:-1003728720677:topic:3",
        "channel": "telegram",
        "to": "-1003728720677:topic:3",
        "deliver": true,
        "allowUnsafeExternalContent": true,
        "messageTemplate": "{{message}}"
      },
      {
        "id": "n8n-string",
