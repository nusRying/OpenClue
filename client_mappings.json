"hooks": {
    "enabled": true,
    "path": "/hooks",
    "token": "<anycode>",
    "allowRequestSessionKey": true,
    "internal": {
      "enabled": true,
      "entries": {
        "n8n-webhook": {
          "enabled": true
        }
      }
    },
    "mappings": [
      {
        "id": "n8n-promo",
        "match": { "path": "n8n-promo" },
        "action": "agent",
        "agentId": "promo",
        "sessionKey": "agent:promo:telegram:group:-1003728720677:topic:1239",
        "channel": "telegram",
        "to": "-1003728720677:topic:1239",
        "deliver": true,
        "allowUnsafeExternalContent": true,
        "messageTemplate": "{{message}}"
      },
      {
        "id": "n8n-main",
        "match": { "path": "n8n-main" },
        "action": "agent",
