        "action": "agent",
        "agentId": "string",
        "sessionKey": "agent:string:telegram:group:-1003728720677:topic:2",
        "channel": "telegram",
        "to": "-1003728720677:topic:2",
        "deliver": true,
        "allowUnsafeExternalContent": true,
        "messageTemplate": "{{message}}"
      }
    ]
