      "typeVersion": 4.1,
      "position": [ 600, 50 ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "method": "PATCH",
        "url": "=https://base.kutraa.com/rest/v1/agents?name=eq.{{ $json.metadata.agentId || 'main' }}",
