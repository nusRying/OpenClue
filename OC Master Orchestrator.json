        "jsonBody": "={{ JSON.stringify({\n  p_session_key: $json.metadata.sessionKey || 'UNTRACKED',\n  p_message: { role: 'agent', content: $json.message || 'Mission Pulse', timestamp: $now.toISOString() },\n  p_agent_id: $json.metadata.agentId || 'main',\n  p_client_name: 'Mission Client'\n}) }}",
        "options": {}
