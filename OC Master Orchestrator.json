{
  "name": "OpenClue - Master Orchestrator v5.1.16 (Resonance-Stabilized)",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "OpenCluePulse",
        "responseMode": "lastNode",
        "options": {}
      },
      "id": "agent-events",
      "name": "Agent Event Inbound",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [ 0, 100 ]
    },
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "OpenClueActions",
        "responseMode": "lastNode",
        "options": {}
      },
      "id": "frontend-actions",
      "name": "Frontend Action Inbound",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [ 0, 300 ]
    },
    {
      "parameters": {
        "jsCode": "// Normalize webhook payload\nconst raw = $input.item.json;\nconst data = raw.body && typeof raw.body === 'object' && !Array.isArray(raw.body) ? raw.body : raw;\nreturn { json: data };"
      },
      "id": "body-unwrap",
      "name": "Body Unwrap",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [ 150, 200 ]
    },
    {
      "parameters": {
        "dataType": "string",
        "value1": "={{ ($json.action || $json.event_type || 'unclassified').toString() }}",
        "rules": {
          "rules": [
            { "value2": "message:sent", "output": 0 },
            { "value2": "message:received", "output": 0 },
            { "value2": "session_end", "output": 3 },
            { "operation": "startsWith", "value2": "session_", "output": 1 },
            { "value2": "broadcast", "output": 2 },
            { "operation": "startsWith", "value2": "task:", "output": 2 }
          ]
        },
        "fallbackOutput": 3
      },
      "id": "orchestrator-switch",
      "name": "Absolute Router",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 1,
      "position": [ 350, 200 ]
    },
    {
      "parameters": {
        "jsCode": "// Resolve broadcast - Pinned topics for Telegram\nconst item = $input.item.json;\nconst messageText = item.message || item.description || 'Broadcast pulse.';\n\nconst MAPPINGS = [\n  { agentName: 'promo', to: '-1003728720677:topic:1239', sessionKey: 'agent:promo:telegram:group:-1003728720677:topic:1239' },\n  { agentName: 'main', to: '-1003728720677:topic:1', sessionKey: 'agent:main:telegram:group:-1003728720677:topic:1' },\n  { agentName: 'digit', to: '-1003728720677:topic:3', sessionKey: 'agent:digit:telegram:group:-1003728720677:topic:3' },\n  { agentName: 'string', to: '-1003728720677:topic:2', sessionKey: 'agent:string:telegram:group:-1003728720677:topic:2' }\n];\n\nreturn MAPPINGS.map(m => ({\n  json: {\n    ...m,\n    message: messageText,\n    original: item\n  }\n}));"
      },
      "id": "broadcast-resolver",
      "name": "Broadcast Resolver",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [ 550, 400 ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=http://tofyq3lga15o3184lxde506q:18789/hooks/n8n-{{ $json.agentName }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "Bearer 46cf3441242627eabf8eb5c32d2e0d7f" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"message\": \"{{ $json.message }}\",\n  \"to\": \"{{ $json.to }}\",\n  \"sessionKey\": \"{{ $json.sessionKey }}\",\n  \"channel\": \"telegram\"\n}",
        "options": {}
      },
      "id": "gateway-pulse",
      "name": "Neural Gateway Pulse",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [ 800, 400 ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "// Aggregate signals back to a single pulse for logging and response\nconst input = $input.all();\nconst first = input[0].json;\nconst original = first.original || first._raw || {};\n\nreturn {\n  json: {\n    event_type: 'broadcast',\n    description: original.message || 'Signal resonance optimized.',\n    metadata: {\n      source: 'Orchestrator v5.1.16',\n      pulse_count: input.length,\n      timestamp: new Date().toISOString()\n    }\n  }\n};"
      },
      "id": "signal-aggregator",
      "name": "Signal Aggregator",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [ 1050, 300 ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://base.kutraa.com/rest/v1/activity_log",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey", "value": "eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9.eyJpc3MiOiJzdXBhYmFzZSIsImlhdCI6MTc3NjI0NDU2MCwiZXhwIjo0OTMxOTE4MTYwLCJyb2xlIjoiYW5vbiJ9.RJRl9UsbEImEOQYPBy6nZds-RYlaTclQQj2pJ8uJb6U" },
            { "name": "Authorization", "value": "Bearer eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9.eyJpc3MiOiJzdXBhYmFzZSIsImlhdCI6MTc3NjI0NDU2MCwiZXhwIjo0OTMxOTE4MTYwLCJyb2xlIjoiYW5vbiJ9.RJRl9UsbEImEOQYPBy6nZds-RYlaTclQQj2pJ8uJb6U" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($json) }}",
        "options": {}
      },
      "id": "action-log",
      "name": "Neural Persistence: Log",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [ 1250, 300 ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "options": {
          "responseBody": "={{ JSON.stringify({\n  mission: 'acknowledged',\n  signal_id: $execution.id,\n  resonance: 'v5.1.16',\n  timestamp: $now.toISOString()\n}) }}"
        }
      },
      "id": "final-response",
      "name": "Mission Response Gate",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [ 1450, 300 ]
    }
  ],
  "connections": {
    "Agent Event Inbound": { "main": [ [ { "node": "Body Unwrap", "type": "main", "index": 0 } ] ] },
    "Frontend Action Inbound": { "main": [ [ { "node": "Body Unwrap", "type": "main", "index": 0 } ] ] },
    "Body Unwrap": { "main": [ [ { "node": "Absolute Router", "type": "main", "index": 0 } ] ] },
    "Absolute Router": { 
      "main": [ 
        [],
        [],
        [ { "node": "Broadcast Resolver", "type": "main", "index": 0 } ],
        [ { "node": "Signal Aggregator", "type": "main", "index": 0 } ]
      ] 
    },
    "Broadcast Resolver": { "main": [ [ { "node": "gateway-pulse", "type": "main", "index": 0 } ] ] },
    "gateway-pulse": { "main": [ [ { "node": "Signal Aggregator", "type": "main", "index": 0 } ] ] },
    "Signal Aggregator": { "main": [ [ { "node": "action-log", "type": "main", "index": 0 } ] ] },
    "action-log": { "main": [ [ { "node": "final-response", "type": "main", "index": 0 } ] ] }
  },
  "settings": {
    "executionOrder": "v1",
    "callerPolicy": "workflowsFromSameOwner"
  }
}
