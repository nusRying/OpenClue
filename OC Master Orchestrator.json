{
  "name": "OpenClue - Master Orchestrator v2.5",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "oc-signals-v2",
        "responseMode": "lastNode",
        "options": {}
      },
      "id": "agent-events",
      "name": "Agent Event Inbound",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [
        0,
        100
      ]
    },
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "oc-actions-v2",
        "responseMode": "lastNode",
        "options": {}
      },
      "id": "frontend-actions",
      "name": "Frontend Action Inbound",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [
        0,
        300
      ]
    },
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "minutes",
              "minutesInterval": 30
            }
          ]
        }
      },
      "id": "health-check-cron",
      "name": "Operational Sentry (30m)",
      "type": "n8n-nodes-base.cron",
      "typeVersion": 1,
      "position": [
        0,
        700
      ]
    },
    {
      "parameters": {
        "dataType": "string",
        "value1": "={{ $json.action || $json.event_type }}",
        "rules": {
          "rules": [
            {
              "value2": "message:sent",
              "output": 0
            },
            {
              "value2": "message:received",
              "output": 0
            },
            {
              "value2": "session_end",
              "output": 3
            },
            {
              "operation": "startsWith",
              "value2": "session_",
              "output": 1
            },
            {
              "operation": "startsWith",
              "value2": "task:",
              "output": 2
            }
          ]
        }
      },
      "id": "orchestrator-switch",
      "name": "Master Action Router",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 1,
      "position": [
        300,
        200
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://base.kutraa.com/rest/v1/rpc/append_conversation_message",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9.eyJpc3MiOiJzdXBhYmFzZSIsImlhdCI6MTc3NjI0NDU2MCwiZXhwIjo0OTMxOTE4MTYwLCJyb2xlIjoiYW5vbiJ9.RJRl9UsbEImEOQYPBy6nZds-RYlaTclQQj2pJ8uJb6U"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"p_session_key\": \"{{ $json.metadata.sessionKey }}\",\n  \"p_message\": {\n    \"role\": \"{{ $json.event_type === 'message:sent' ? 'agent' : 'user' }}\",\n    \"content\": \"{{ $json.message }}\",\n    \"timestamp\": \"{{ $now.toISOString() }}\"\n  },\n  \"p_agent_id\": \"{{ $json.metadata.agentId }}\",\n  \"p_client_name\": \"{{ $json.metadata.senderName || 'Client' }}\"\n}",
        "options": {}
      },
      "id": "action-conversation",
      "name": "Sync Conversations",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        550,
        50
      ]
    },
    {
      "parameters": {
        "method": "PATCH",
        "url": "=https://base.kutraa.com/rest/v1/agents?name=eq.{{ $json.metadata.agentId }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9.eyJpc3MiOiJzdXBhYmFzZSIsImlhdCI6MTc3NjI0NDU2MCwiZXhwIjo0OTMxOTE4MTYwLCJyb2xlIjoiYW5vbiJ9.RJRl9UsbEImEOQYPBy6nZds-RYlaTclQQj2pJ8uJb6U"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"status\": \"{{ $json.event_type === 'session_start' ? 'online' : 'offline' }}\",\n  \"last_heartbeat\": \"{{ $now.toISOString() }}\"\n}",
        "options": {}
      },
      "id": "action-status",
      "name": "Sync Master Status",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        550,
        250
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://base.kutraa.com/rest/v1/activity_log",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9.eyJpc3MiOiJzdXBhYmFzZSIsImlhdCI6MTc3NjI0NDU2MCwiZXhwIjo0OTMxOTE4MTYwLCJyb2xlIjoiYW5vbiJ9.RJRl9UsbEImEOQYPBy6nZds-RYlaTclQQj2pJ8uJb6U"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"agent_id\": \"{{ $json.metadata.agentId }}\",\n  \"event_type\": \"{{ $json.action || $json.event_type }}\",\n  \"description\": \"{{ $json.message || 'System Action' }}\",\n  \"metadata\": {{ JSON.stringify($json.metadata || {}) }}\n}",
        "options": {}
      },
      "id": "action-log",
      "name": "Timeline Synchronizer",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        800,
        150
      ]
    },
    {
      "parameters": {
        "resource": "chat",
        "model": "gpt-4-turbo",
        "messages": {
          "messageValues": [
            {
              "role": "system",
              "content": "You are the OpenClue Performance Auditor. Summarize the following session into 3 strategic bullet points focusing on outcomes and agent performance."
            },
            {
              "role": "user",
              "content": "={{ $json.message || 'Session ended without content.' }}"
            }
          ]
        }
      },
      "id": "ai-summarizer",
      "name": "AI Mission Summarizer",
      "type": "n8n-nodes-base.openAi",
      "typeVersion": 1,
      "position": [
        550,
        500
      ],
      "credentials": {
        "openAiApi": {
          "id": "YOUR_OPENAI_ID",
          "name": "OpenAI Account"
        }
      }
    },
    {
      "parameters": {
        "method": "PATCH",
        "url": "=https://base.kutraa.com/rest/v1/projects?id=eq.{{ $json.metadata.project_id || '92722fc2-fd08-408a-881a-1395a9a29d5c' }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9.eyJpc3MiOiJzdXBhYmFzZSIsImlhdCI6MTc3NjI0NDU2MCwiZXhwIjo0OTMxOTE4MTYwLCJyb2xlIjoiYW5vbiJ9.RJRl9UsbEImEOQYPBy6nZds-RYlaTclQQj2pJ8uJb6U"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"intelligence_summary\": \"{{ $json.message.content }}\"\n}",
        "options": {}
      },
      "id": "action-intel",
      "name": "Push Intelligence",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        800,
        500
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://base.kutraa.com/rest/v1/agents?status=eq.online",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9.eyJpc3MiOiJzdXBhYmFzZSIsImlhdCI6MTc3NjI0NDU2MCwiZXhwIjo0OTMxOTE4MTYwLCJyb2xlIjoiYW5vbiJ9.RJRl9UsbEImEOQYPBy6nZds-RYlaTclQQj2pJ8uJb6U"
            }
          ]
        }
      },
      "id": "get-online-agents",
      "name": "Scan Agent Health",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        250,
        700
      ]
    },
    {
      "parameters": {
        "options": {
          "responseCode": 200
        }
      },
      "id": "respond-node",
      "name": "Respond to Probe",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [
        1100,
        300
      ]
    }
  ],
  "connections": {
    "Agent Event Inbound": {
      "main": [
        [
          {
            "node": "Master Action Router",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Frontend Action Inbound": {
      "main": [
        [
          {
            "node": "Master Action Router",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Operational Sentry (30m)": {
      "main": [
        [
          {
            "node": "Scan Agent Health",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Master Action Router": {
      "main": [
        [
          {
            "node": "Sync Conversations",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Sync Master Status",
            "type": "main",
            "index": 0
          }
        ],
        [],
        [
          {
