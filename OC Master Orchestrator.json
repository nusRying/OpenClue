{
  "name": "OpenClue - Master Orchestrator v5.1.17 (Unified-Resonance)",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "OpenCluePulse",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "agent-events",
      "name": "Agent Event Inbound",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [ 0, 100 ]
    },
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "OpenClueActions",
