          "parameters": [
            { "name": "Authorization", "value": "Bearer 46cf3441242627eabf8eb5c32d2e0d7f" }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "message", "value": "={{ $json.message }}" }
