{
  "name": "OpenClue - Master Orchestrator [DEBUG]",
  "nodes": [
    {
      "parameters": { "httpMethod": "POST", "path": "oc-signals-v2", "responseMode": "lastNode", "options": {} },
      "id": "Agent Event Inbound",
      "name": "Agent Event Inbound",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [ 100, 100 ]
    },
    {
      "parameters": { "httpMethod": "POST", "path": "oc-actions-v2", "responseMode": "lastNode", "options": {} },
      "id": "Frontend Action Inbound",
      "name": "Frontend Action Inbound",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [ 100, 400 ]
    },
    {
      "parameters": { "rule": { "interval": [ { "field": "minutes", "minutesInterval": 30 } ] } },
      "id": "Operational Sentry (30m)",
      "name": "Operational Sentry (30m)",
      "type": "n8n-nodes-base.cron",
      "typeVersion": 1,
      "position": [ 100, 1000 ]
    },
    {
      "parameters": {
        "dataType": "string",
        "value1": "={{ $json.action || $json.event_type }}",
        "rules": {
          "rules": [
            { "value2": "session_end", "output": 4 },
            { "value2": "message:sent", "output": 0 },
            { "value2": "message:received", "output": 0 },
            { "operation": "startsWith", "value2": "session_", "output": 1 },
            { "value2": "task:create", "output": 2 },
            { "value2": "task:assign", "output": 2 },
            { "value2": "broadcast", "output": 3 }
          ]
        }
      },
      "id": "Master Action Router",
      "name": "Master Action Router",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 1,
      "position": [ 350, 300 ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://base.kutraa.com/rest/v1/rpc/append_conversation_message",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey", "value": "eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9.eyJpc3MiOiJzdXBhYmFzZSIsImlhdCI6MTc3NjI0NDU2MCwiZXhwIjo0OTMxOTE4MTYwLCJyb2xlIjoiYW5vbiJ9.RJRl9UsbEImEOQYPBy6nZds-RYlaTclQQj2pJ8uJb6U" },
            { "name": "Authorization", "value": "Bearer eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9.eyJpc3MiOiJzdXBhYmFzZSIsImlhdCI6MTc3NjI0NDU2MCwiZXhwIjo0OTMxOTE4MTYwLCJyb2xlIjoiYW5vbiJ9.RJRl9UsbEImEOQYPBy6nZds-RYlaTclQQj2pJ8uJb6U" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"p_session_key\": \"{{ $json.metadata.sessionKey }}\",\n  \"p_agent_id\": \"{{ $json.metadata.agentId || 'main' }}\",\n  \"p_message\": {\n    \"role\": \"{{ $json.event_type === 'message:sent' ? 'agent' : 'user' }}\",\n    \"content\": \"{{ $json.message }}\"\n  }\n}",
        "options": {}
      },
      "id": "Sync Conversations",
      "name": "Sync Conversations",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [ 650, 100 ]
    },
    {
      "parameters": {
        "method": "PATCH",
        "url": "=https://base.kutraa.com/rest/v1/agents?or=(id.eq.{{ $json.metadata.agentId }},name.eq.{{ $json.metadata.agentId }})",
        "sendHeaders": true,
        "headerParameters": { "parameters": [ { "name": "apikey", "value": "eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9.eyJpc3MiOiJzdXBhYmFzZSIsImlhdCI6MTc3NjI0NDU2MCwiZXhwIjo0OTMxOTE4MTYwLCJyb2xlIjoiYW5vbiJ9.RJRl9UsbEImEOQYPBy6nZds-RYlaTclQQj2pJ8uJb6U" } ] },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"status\": \"{{ $json.event_type === 'session_start' ? 'online' : 'offline' }}\",\n  \"last_heartbeat\": \"{{ $now.toISOString() }}\"\n}",
        "options": {}
      },
      "id": "Sync Master Status",
      "name": "Sync Master Status",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [ 650, 250 ]
    },
    {
      "parameters": { "options": {} },
      "id": "Respond to Probe",
      "name": "Respond to Probe",
      "type": "n8n-nodes-base.noOp",
      "typeVersion": 1,
      "position": [ 1300, 300 ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://base.kutraa.com/rest/v1/activity_log",
        "sendHeaders": true,
        "headerParameters": { "parameters": [ { "name": "apikey", "value": "eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9.eyJpc3MiOiJzdXBhYmFzZSIsImlhdCI6MTc3NjI0NDU2MCwiZXhwIjo0OTMxOTE4MTYwLCJyb2xlIjoiYW5vbiJ9.RJRl9UsbEImEOQYPBy6nZds-RYlaTclQQj2pJ8uJb6U" } ] },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"agent_id\": \"{{ $json.metadata.agentId || 'main' }}\",\n  \"event_type\": \"{{ $json.action || $json.event_type }}\",\n  \"description\": \"{{ $json.message || 'System Action' }}\"\n}",
        "options": {}
      },
      "id": "Timeline Synchronizer",
      "name": "Timeline Synchronizer",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [ 950, 300 ]
    }
  ],
  "connections": {
    "Agent Event Inbound": { "main": [ [ { "node": "Timeline Synchronizer", "type": "main", "index": 0 }, { "node": "Master Action Router", "type": "main", "index": 0 } ] ] },
    "Frontend Action Inbound": { "main": [ [ { "node": "Timeline Synchronizer", "type": "main", "index": 0 }, { "node": "Master Action Router", "type": "main", "index": 0 } ] ] },
    "Master Action Router": {
      "main": [
        [ { "node": "Sync Conversations", "type": "main", "index": 0 } ],
        [ { "node": "Sync Master Status", "type": "main", "index": 0 } ]
      ]
    },
    "Sync Conversations": { "main": [ [ { "node": "Respond to Probe", "type": "main", "index": 0 } ] ] },
    "Sync Master Status": { "main": [ [ { "node": "Respond to Probe", "type": "main", "index": 0 } ] ] },
    "Timeline Synchronizer": { "main": [ [ { "node": "Respond to Probe", "type": "main", "index": 0 } ] ] }
  },
  "settings": { "executionOrder": "v1" }
}
