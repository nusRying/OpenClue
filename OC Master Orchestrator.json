      "id": "action-status",
      "name": "Neural Persistence: Status",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [ 600, 200 ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "// Resolve broadcast: map agent UUIDs to names and create one item per target agent\nconst item = $input.item.json;\nconst meta = item.metadata || {};\n\n// UUID-to-name lookup\nconst AGENT_MAP = {\n  'b760f890-e68b-48a7-9c93-a74a2ba7fa89': 'main',\n  '1b92b1f5-570f-4c15-95cf-64eebcb03647': 'promo',\n  '161deb43-0dc0-4b2d-9c09-56387314ad59': 'digit',\n  '7d768392-879f-4bb4-ae40-c4ac96aea00a': 'string'\n};\n\nconst agentIds = meta.agent_ids || [];\nconst agentNames = agentIds.map(id => AGENT_MAP[id] || id).filter(Boolean);\nif (agentNames.length === 0) agentNames.push('main');\n\nconst items = agentNames.map(name => ({\n  json: {\n    agentName: name,\n    message: item.message || item.description || 'Broadcast pulse.',\n    channel: meta.channel || 'telegram',\n    to: meta.to || '',\n    sessionKey: meta.sessionKey || ''\n  }\n}));\n\nreturn items;"
      },
      "id": "broadcast-resolver",
      "name": "Broadcast Resolver",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [ 550, 400 ]
    },
