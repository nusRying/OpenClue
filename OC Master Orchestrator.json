    {
      "parameters": {
        "jsCode": "// Broadcast Resolver\nconst item = $input.item.json;\nreturn [\n  { name: 'promo', to: '-1003728720677:topic:1239' },\n  { name: 'main', to: '-1003728720677:topic:1' },\n  { name: 'digit', to: '-1003728720677:topic:3' },\n  { name: 'string', to: '-1003728720677:topic:2' }\n].map(m => ({ json: { ...m, message: item.message, project_id: item.project_id } }));"
      },
