          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"event_type\": \"broadcast\",\n  \"message\": \"{{ $json.message }}\",\n  \"metadata\": {\n    \"agentId\": \"{{ $json.agentName }}\",\n    \"sessionKey\": \"{{ $json.sessionKey }}\"\n  }\n}",
        "options": {}
