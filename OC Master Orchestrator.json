    {
      "parameters": {
        "jsCode": "// Broadcast Resolver - Propagate project_id and enforce high priority\nconst item = $input.item.json;\nconst msg = item.message || 'Signal pulse.';\nconst pid = item.project_id;\nconst MAPS = [\n  { name: 'promo', to: '-1003728720677:topic:1239', key: 'agent:promo:telegram:group:-1003728720677:topic:1239' },\n  { name: 'main', to: '-1003728720677:topic:1', key: 'agent:main:telegram:group:-1003728720677:topic:1' },\n  { name: 'digit', to: '-1003728720677:topic:3', key: 'agent:digit:telegram:group:-1003728720677:topic:3' },\n  { name: 'string', to: '-1003728720677:topic:2', key: 'agent:string:telegram:group:-1003728720677:topic:2' }\n];\nreturn MAPS.map(m => ({ json: { ...m, message: msg, project_id: pid, original: item } }));"
      },
      "id": "broadcast-resolver",
      "name": "Broadcast Resolver",
      "type": "n8n-nodes-base.code",
