    {
      "parameters": {
        "jsCode": "// Aggregate logs\nconst item = $json._raw || $json;\nreturn {\n  json: {\n    event_type: 'broadcast',\n    description: item.message || 'Mission resonance confirmed.',\n    metadata: {\n      source: 'Orchestrator v5.1.14',\n      path: 'Dual-Channel Active'\n    }\n  }\n};"
      },
      "id": "payload-shield",
