      "name": "Frontend Action Inbound",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [ 0, 300 ]
    },
    {
      "parameters": {
        "jsCode": "// Normalize webhook payload\nconst raw = $input.item.json;\nconst data = raw.body && typeof raw.body === 'object' && !Array.isArray(raw.body) ? raw.body : raw;\nreturn { json: data };"
      },
      "id": "body-unwrap",
      "name": "Body Unwrap",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [ 150, 200 ]
    },
    {
      "parameters": {
        "dataType": "string",
        "value1": "={{ ($json.action || $json.event_type || 'unclassified').toString() }}",
        "rules": {
          "rules": [
            { "value2": "message:sent", "output": 0 },
            { "value2": "message:received", "output": 0 },
            { "value2": "session_end", "output": 3 },
            { "operation": "startsWith", "value2": "session_", "output": 1 },
            { "value2": "broadcast", "output": 2 },
            { "operation": "startsWith", "value2": "task:", "output": 2 }
          ]
        },
        "fallbackOutput": 3
      },
      "id": "orchestrator-switch",
      "name": "Absolute Router",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 1,
      "position": [ 350, 200 ]
    },
    {
      "parameters": {
        "jsCode": "// Resolve broadcast - Dual path + Explicit MAPPINGS\nconst item = $input.item.json;\nconst messageText = item.message || item.description || 'Broadcast pulse.';\n\nconst MAPPINGS = [\n  {\n    agentName: 'promo',\n    to: '-1003728720677:topic:1239',\n    sessionKey: 'agent:promo:telegram:group:-1003728720677:topic:1239'\n  },\n  {\n    agentName: 'main',\n    to: '-1003728720677:topic:1',\n    sessionKey: 'agent:main:telegram:group:-1003728720677:topic:1'\n  },\n  {\n    agentName: 'digit',\n    to: '-1003728720677:topic:3',\n    sessionKey: 'agent:digit:telegram:group:-1003728720677:topic:3'\n  },\n  {\n    agentName: 'string',\n    to: '-1003728720677:topic:2',\n    sessionKey: 'agent:string:telegram:group:-1003728720677:topic:2'\n  }\n];\n\nreturn MAPPINGS.map(m => ({\n  json: {\n    ...m,\n    message: messageText,\n    channel: 'telegram',\n    _raw: item\n  }\n}));"
      },
      "id": "broadcast-resolver",
      "name": "Broadcast Resolver",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [ 550, 400 ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=http://tofyq3lga15o3184lxde506q:18789/hooks/n8n-{{ $json.agentName }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "Bearer 46cf3441242627eabf8eb5c32d2e0d7f" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"message\": \"{{ $json.message }}\",\n  \"to\": \"{{ $json.to }}\",\n  \"sessionKey\": \"{{ $json.sessionKey }}\",\n  \"channel\": \"{{ $json.channel }}\"\n}",
        "options": {}
      },
      "id": "gateway-pulse",
      "name": "Path A: Gateway Pulse",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [ 800, 350 ],
