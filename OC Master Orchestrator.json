          "parameters": [
            { "name": "Authorization", "value": "Basic S3V0cmFhOkt1dHJhYTEyMTM=" },
            { "name": "X-Agent-Token", "value": "123067fac98b189c77bda93c45acb9b82cb142a01e3249cd" },
            { "name": "X-API-Key", "value": "123067fac98b189c77bda93c45acb9b82cb142a01e3249cd" },
            { "name": "X-Auth-Token", "value": "Bearer 123067fac98b189c77bda93c45acb9b82cb142a01e3249cd" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"message\": \"{{ $json.message }}\",\n  \"sessionKey\": \"{{ $json.sessionKey }}\",\n  \"to\": \"{{ $json.to }}\",\n  \"channel\": \"{{ $json.channel }}\"\n}",
        "options": {}
