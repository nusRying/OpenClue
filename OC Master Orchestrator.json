{
  "name": "OpenClue - Master Orchestrator v5.4.0 (Native Task Flow Integration)",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "OpenCluePulse",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "agent-events",
      "name": "Agent Event Inbound",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2.1,
      "position": [-200, 200]
    },
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "OpenClueActions",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "frontend-actions",
      "name": "Frontend Action Inbound",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2.1,
      "position": [-200, 400]
    },
    {
      "parameters": {
        "jsCode": "// Normalize payload\nconst raw = $input.item.json;\nconst data = raw.body && typeof raw.body === 'object' && !Array.isArray(raw.body) ? raw.body : raw;\nconst project_id = data.project_id || (data.metadata ? data.metadata.project_id : (data.record ? data.record.project_id : null));\nreturn { json: { ...data, project_id } };"
      },
      "id": "body-unwrap",
      "name": "Body Unwrap",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [50, 300]
    },
    {
      "parameters": {
        "dataType": "string",
        "value1": "={{ ($json.action || $json.event_type || ($json.record ? 'task:event' : 'unclassified')).toString() }}",
        "rules": {
          "rules": [
            { "value2": "message:sent", "output": 0 },
            { "value2": "message:received", "output": 0 },
            { "operation": "startsWith", "value2": "task:", "output": 1 },
            { "value2": "task:event", "output": 1 },
            { "value2": "broadcast", "output": 2 },
            { "operation": "startsWith", "value2": "session_", "output": 3 }
          ]
        },
        "fallbackOutput": 3
      },
      "id": "orchestrator-switch",
      "name": "Absolute Router",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 1,
      "position": [300, 300]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            { "name": "taskTitle", "value": "={{ $json.record.title || $json.title }}", "type": "string" },
            { "name": "taskDescription", "value": "={{ $json.record.description || $json.description }}", "type": "string" },
            { "name": "agentName", "value": "={{ $json.record.assignee_names || $json.assignee_names || [] }}", "type": "array" },
            { "name": "project_id", "value": "={{ $json.project_id }}", "type": "string" }
          ]
        }
      },
      "id": "task-field-extractor",
      "name": "Task Field Extractor",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.2,
      "position": [550, 150]
    },
    {
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "conditions": [
                  { "leftValue": "={{ $json.agentName }}", "rightValue": "promo", "operator": { "type": "array", "operation": "contains" } }
                ]
              },
              "renameOutput": true,
              "outputKey": "Promo"
            },
            {
              "conditions": {
                "conditions": [
                  { "leftValue": "={{ $json.agentName }}", "rightValue": "digit", "operator": { "type": "array", "operation": "contains" } }
                ]
              },
              "renameOutput": true,
              "outputKey": "Digit"
            },
            {
              "conditions": {
                "conditions": [
                  { "leftValue": "={{ $json.agentName }}", "rightValue": "string", "operator": { "type": "array", "operation": "contains" } }
                ]
              },
              "renameOutput": true,
              "outputKey": "String"
            },
            {
              "conditions": {
                "conditions": [
                  { "leftValue": "={{ $json.agentName }}", "rightValue": "main", "operator": { "type": "array", "operation": "contains" } }
                ]
              },
              "renameOutput": true,
              "outputKey": "Main"
            }
          ]
        },
        "options": { "allMatchingOutputs": true }
      },
      "id": "task-agent-switch",
      "name": "Task Agent Switch",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [800, 150]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://tofyq3lga15o3184lxde506q:18789/hooks/n8n-promo",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "Bearer 46cf3441242627eabf8eb5c32d2e0d7f" }
